---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('journey')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Base title="The journey" description="Install diary for a UK solar, battery and Predbat project, from quote to commissioning to live automation, with the lessons learned along the way.">
  <section class="reveal">
    <p class="kicker">Install diary</p>
    <h1>The journey</h1>
    <p style="max-width:46rem">
      From quote to commissioning to a battery that runs itself, written as it happened, including
      the bits that didn't go to plan.
    </p>
  </section>

  <section style="margin-top:2.5rem">
    {posts.map((p) => (
      <article class="panel" style="margin-bottom:1.2rem">
        <p class="kicker" style="margin-bottom:0.5rem">{fmtDate(p.data.date)}</p>
        <h2 style="margin:0 0 0.5rem"><a href={`/journey/${p.id}/`} style="text-decoration:none">{p.data.title}</a></h2>
        <p style="margin:0">{p.data.summary}</p>
        <p style="margin:0.8rem 0 0">
          {p.data.tags.map((t) => <span class="tag">{t}</span>)}
        </p>
      </article>
    ))}
  </section>
</Base>
