---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/global.css';

const OCTOPUS_REFERRAL = 'https://share.octopus.energy/lush-spark-49';
const AXLE_REFERRAL = 'https://vpp.axle.energy/landing?ref=R-QADMOHUO';

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  jsonLd?: object;
}
const {
  title,
  description = 'A UK solar and battery install, documented in numbers. 10.45 kWp of Aiko panels, a Sigenergy inverter, Octopus Agile, and Home Assistant with Predbat. Real daily performance data, published automatically.',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const siteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Solar by Numbers',
  url: Astro.site?.href,
  description:
    'Real daily performance data from a UK solar and battery install: Aiko panels, Sigenergy inverter, Octopus Agile, Home Assistant and Predbat.',
};

const nav = [
  ['/', 'home'],
  ['/stats/', 'stats'],
  ['/system/', 'system'],
  ['/stack/', 'stack'],
  ['/configs/', 'configs'],
  ['/journey/', 'journey'],
  ['/tariff/', 'tariff'],
];
const path = Astro.url.pathname;
const isCurrent = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Solar by Numbers</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Solar by Numbers journey" href="/rss.xml" />
    <meta property="og:site_name" content="Solar by Numbers" />
    <meta property="og:title" content={`${title} · Solar by Numbers`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} · Solar by Numbers`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site).href} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd ?? siteJsonLd)} />
  </head>
  <body>
    <header class="site">
      <div class="bar">
        <a href="/" class="wordmark"><span class="sun" aria-hidden="true"></span>solar <em>by numbers</em></a>
        <input type="checkbox" id="nav-toggle" aria-hidden="true" />
        <label for="nav-toggle" class="nav-burger" aria-label="Menu">≡</label>
        <nav class="site" aria-label="Main">
          <ul>
            {nav.map(([href, label]) => (
              <li><a href={href} aria-current={isCurrent(href) ? 'page' : undefined}>{label}</a></li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site">
      <div class="wrap cols">
        <div>
          <p style="color:var(--cream)"><strong>Solar by Numbers</strong> is the record of one household's solar and battery install: 10.45 kWp on an east/west roof in Hampshire, a 15 kWh battery, and Home Assistant with Predbat running the lot. The numbers update every night, straight from the inverter.</p>
          <p class="muted">No sponsors. The referral links below are the only money this site makes, and they pay you as much as they pay us.</p>
        </div>
        <div>
          <p><strong style="color:var(--cream)">Thinking of switching to Octopus?</strong><br />
          We're on Agile import, with fixed 12p export lined up once our export certification
          clears. Sign up through this link and we both get £50:</p>
          <a class="btn octopus" href={OCTOPUS_REFERRAL} rel="noopener"><span aria-hidden="true">🐙</span> £50 Octopus referral</a>
          <p style="margin-top:1.5rem"><strong style="color:var(--cream)">Got a home battery?</strong><br />
          Axle pays you for grid-balancing events — we run it in "events only" mode so Predbat
          keeps control the rest of the time. Sign up through this link and we both get £25:</p>
          <a class="btn axle" href={AXLE_REFERRAL} rel="noopener"><span aria-hidden="true">⚡</span> £25 Axle referral</a>
          <p class="muted" style="margin-top:1rem">
            <a href="/journey/">Install diary</a> · <a href="/configs/">Predbat configs</a> · <a href="/stats/">Live stats</a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
